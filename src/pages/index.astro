---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import "../styles/global.css";

// Fetch server-side (Astro)
const res = await fetch("http://localhost:4321/api/currencies");
const currencies = await res.json();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main class="p-8 max-w-xl mx-auto">
      <h1 class="text-red-500! text-5xl mb-6">🧑‍🚀 Hello, Astronaut!</h1>

      <h2 class="text-2xl mb-4 font-bold">💱 Currency Exchanger</h2>

      <form id="converter" class="flex flex-col gap-4">
        <input
          type="number"
          id="amount"
          placeholder="Amount"
          class="border p-2 rounded"
        />

        <div class="flex gap-2">
          <select id="from" class="border p-2 rounded w-full">
            {
              Object.entries(currencies).map(([code, name]) => (
                <option value={code}>
                  {code} - {name}
                </option>
              ))
            }
          </select>

          <select id="to" class="border p-2 rounded w-full">
            {
              Object.entries(currencies).map(([code, name]) => (
                <option value={code}>
                  {code} - {name}
                </option>
              ))
            }
          </select>
        </div>
        <pre>{JSON.stringify(currencies, null, 2)}</pre>

        <button
          type="submit"
          class="bg-blue-500 text-white p-2 rounded hover:bg-blue-600"
        >
          Convert
        </button>
      </form>

      <h3 id="result" class="mt-6 text-xl font-semibold"></h3>
    </main>

    <Footer />

    <!-- Client-side logic -->
    <script>
      const form = document.getElementById(
        "converter",
      ) as HTMLFormElement | null;
      const resultEl = document.getElementById("result") as HTMLElement | null;

      if (form && resultEl) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();

          const amount = document.getElementById("amount") as HTMLInputElement;
          const from = document.getElementById("from") as HTMLSelectElement;
          const to = document.getElementById("to") as HTMLSelectElement;

          const amountValue = amount.value;
          const fromValue = from.value;
          const toValue = to.value;

          if (!amountValue) return;

          try {
            const res = await fetch(
              `https://api.frankfurter.dev/v2/latest?amount=${amountValue}&from=${fromValue}&to=${toValue}`,
            );

            const data = await res.json();
            const rate = data.rates[toValue];

            resultEl.textContent = `${amountValue} ${fromValue} = ${rate} ${toValue}`;
          } catch (err) {
            resultEl.textContent = "Error converting currency";
          }
        });
      }
    </script>
  </body>
</html>
